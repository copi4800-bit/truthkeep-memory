{
  "name": "memory-aegis-v4",
  "version": "4.0.0",
  "description": "Local-first cognitive memory engine for OpenClaw — smart recall, automatic maintenance, and conflict detection.",
  "author": "Hali12",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/copi4800-bit/Memory-aegis.git"
  },
  "keywords": [
    "openclaw",
    "memory",
    "cognitive",
    "local-first",
    "sqlite",
    "rag",
    "knowledge-graph",
    "ai-memory",
    "vietnamese"
  ],
  "type": "module",
  "bin": {
    "aegis-setup": "./dist/cli/setup.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "openclaw.plugin.json",
    "package.json",
    "README.md",
    "src"
  ],
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "prepare": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "setup": "npm run build && node ./dist/cli/setup.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "tsdown": "^0.4.0",
    "@types/better-sqlite3": "^7.6.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
