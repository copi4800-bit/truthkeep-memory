{
  "mcpServers": {
    "truthkeep-memory": {
      "command": "python",
      "args": [
        "-m",
        "truthkeep.mcp"
      ],
      "env": {
        "PYTHONPATH": "/path/to/truthkeep-memory",
        "AEGIS_DB_PATH": "/path/to/truthkeep-memory/memory_aegis.db"
      },
      "description": "Local secure stdio memory engine for Antigravity AI Coding Assistant"
    }
  }
}
